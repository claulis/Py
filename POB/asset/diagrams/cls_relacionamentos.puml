@startuml cls_relacionamentos
title Tipos de Relacionamento - Catalogo de Notacao

skinparam padding 8
skinparam packageStyle rectangle

' =============================================
' 1. DEPENDENCIA
' Notacao: A ..> B
' Semantica: A usa B temporariamente.
'            Mudanca em B pode afetar A.
' =============================================
package "1. Dependencia" {
    class GeradorRelatorio {
        + gerar(): void
    }
    class Conexao {
        + executarSQL(q: String): ResultSet
    }
    GeradorRelatorio ..> Conexao : usa
}

' =============================================
' 2. ASSOCIACAO
' Notacao: A -- B  (bidirecional)
' Semantica: A e B se conhecem mutuamente.
' =============================================
package "2. Associacao" {
    class Medico {
        - crm: String
    }
    class Paciente {
        - cpf: String
    }
    Medico "0..*" -- "0..*" Paciente : atende
}

' =============================================
' 3. ASSOCIACAO DIRIGIDA
' Notacao: A --> B  (unidirecional)
' Semantica: A conhece B, mas B nao conhece A.
' =============================================
package "3. Assoc. Dirigida" {
    class Pedido {
        - numero: int
    }
    class Cliente {
        - cpf: String
    }
    Pedido "0..*" --> "1" Cliente : pertence a
}

' =============================================
' 4. AGREGACAO
' Notacao: A o-- B  (diamante vazio em A)
' Semantica: B e parte de A, mas pode existir
'            independentemente de A.
' =============================================
package "4. Agregacao" {
    class Departamento {
        - nome: String
    }
    class Funcionario {
        - nome: String
    }
    note bottom of Departamento
      Funcionario pode existir
      sem o Departamento.
    end note
    Departamento "1" o-- "0..*" Funcionario : emprega
}

' =============================================
' 5. COMPOSICAO
' Notacao: A *-- B  (diamante cheio em A)
' Semantica: B nao pode existir sem A.
'            Ciclos de vida compartilhados.
' =============================================
package "5. Composicao" {
    class NotaFiscal {
        - numero: int
    }
    class ItemNF {
        - quantidade: int
        - valorUnitario: float
    }
    note bottom of NotaFiscal
      ItemNF nao existe fora
      de uma NotaFiscal.
    end note
    NotaFiscal "1" *-- "1..*" ItemNF : contem
}

' =============================================
' 6. GENERALIZACAO (HERANCA)
' Notacao: A <|-- B
' Semantica: B e um tipo especializado de A.
'            B herda atributos e metodos de A.
' =============================================
package "6. Generalizacao" {
    class Veiculo {
        - placa: String
        + mover(): void
    }
    class Carro {
        - numPortas: int
        + mover(): void
    }
    Veiculo <|-- Carro
}

' =============================================
' 7. REALIZACAO (INTERFACE)
' Notacao: I <|.. C
' Semantica: C implementa o contrato de I.
' =============================================
package "7. Realizacao" {
    interface Exportavel {
        + exportarCSV(): String
        + exportarJSON(): String
    }
    class Relatorio {
        - titulo: String
        + exportarCSV(): String
        + exportarJSON(): String
    }
    Exportavel <|.. Relatorio
}

@enduml
