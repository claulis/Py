@startuml Sistema_Academico

title Sistema Acadêmico - Diagrama de Casos de Uso

' Definição de Atores
actor Aluno
actor Professor
actor Coordenador
actor Administrador
actor SistemaNotificacao

' Define o escopo do sistema
rectangle "Sistema Acadêmico" {
    
    ' Casos de Uso - Gerenciamento de Matrícula
    usecase (Realizar Matrícula) as UC_Matricula
    usecase (Consultar Ofertas) as UC_ConsultarOfertas
    usecase (Desistir de Disciplina) as UC_DesistirDisciplina
    
    ' Casos de Uso - Acadêmicos do Aluno
    usecase (Consultar Notas) as UC_ConsultarNotas
    usecase (Enviar Trabalho) as UC_EnviarTrabalho
    usecase (Visualizar Horário) as UC_VisualizarHorario
    usecase (Consultar Boletim) as UC_ConsultarBoletim
    
    ' Casos de Uso - Professores
    usecase (Lançar Notas) as UC_LancarNotas
    usecase (Criar Plano de Ensino) as UC_CriarPlano
    usecase (Corrigir Trabalho) as UC_CorrigirTrabalho
    usecase (Gerar Pauta) as UC_GerarPauta
    usecase (Enviar Mensagem) as UC_EnviarMensagem
    
    ' Casos de Uso - Coordenação
    usecase (Gerar Relatórios) as UC_GerarRelatorios
    usecase (Aprovar Cancelamento) as UC_AprovarCancelamento
    usecase (Gerenciar Ofertas) as UC_GerenciarOfertas
    usecase (Avaliar Desempenho) as UC_AvaliarDesempenho
    
    ' Casos de Uso - Administração
    usecase (Criar Usuários) as UC_CriarUsuarios
    usecase (Configurar Calendário) as UC_ConfigurarCalendario
    usecase (Gerir Permissões) as UC_GerirPermissoes
    usecase (Fazer Backup) as UC_FazerBackup
    
    ' Relações - Matrícula
    Aluno --> UC_Matricula
    Aluno --> UC_ConsultarOfertas
    Aluno --> UC_DesistirDisciplina : solicita
    UC_Matricula --|> UC_ConsultarOfertas : <<include>>
    
    ' Relações - Académicos Aluno
    Aluno --> UC_ConsultarNotas
    Aluno --> UC_EnviarTrabalho
    Aluno --> UC_VisualizarHorario
    Aluno --> UC_ConsultarBoletim
    UC_ConsultarBoletim --|> UC_ConsultarNotas : <<include>>
    
    ' Relações - Desistência com aprovação
    UC_DesistirDisciplina --|> UC_AprovarCancelamento : <<extend>>
    
    ' Relações - Professores
    Professor --> UC_LancarNotas
    Professor --> UC_CriarPlano
    Professor --> UC_CorrigirTrabalho
    Professor --> UC_GerarPauta
    Professor --> UC_EnviarMensagem
    UC_GerarPauta --|> UC_LancarNotas : <<include>>
    
    ' Relações - Coordenador
    Coordenador --> UC_GerenciarOfertas
    Coordenador --> UC_GerarRelatorios
    Coordenador --> UC_AprovarCancelamento
    Coordenador --> UC_AvaliarDesempenho
    
    ' Relações - Administrador
    Administrador --> UC_CriarUsuarios
    Administrador --> UC_ConfigurarCalendario
    Administrador --> UC_GerirPermissoes
    Administrador --> UC_FazerBackup
    
    ' Notificação (sistema)
    UC_LancarNotas --|> SistemaNotificacao : notifica
    UC_CorrigirTrabalho --|> SistemaNotificacao : notifica
    UC_EnviarMensagem --|> SistemaNotificacao : notifica

}

note right of Aluno
    Acessa funcionalidades
    acadêmicas do sistema
end note

note right of Professor
    Gerencia avaliações
    e planejamento de aulas
end note

note right of Coordenador
    Supervisiona ofertas
    e desempenho acadêmico
end note

note right of Administrador
    Gerencia infraestrutura
    e usuários do sistema
end note

@enduml
